# Which brand to build. Valid values: 1ca, hdx1ca
VITE_BRAND=1ca

# Page <title>
VITE_PAGE_TITLE=1 Clean Air Booking

# Backend auth secret (must match backend's X-API-SECRET)
VITE_API_SECRET=

# n8n lead webhook (fire-and-forget on booking success)
VITE_N8N_WEBHOOK=

# Facebook Pixel ID (for Lead events)
VITE_FB_PIXEL_ID=

# Google Maps JS API key (for address autocomplete)
VITE_PLACES_API_KEY=
